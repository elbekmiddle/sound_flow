# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/obsidian_audio

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-very-long-random-secret-here

# ── Email (choose ONE provider) ───────────────────────────────────────────────

# Option 1: SendGrid (recommended for production)
# Sign up free at https://sendgrid.com → Settings → API Keys
# SENDGRID_API_KEY=SG.xxxxx

# Option 2: Gmail (use App Password, NOT your normal password)
# Google Account → Security → 2FA → App Passwords → create one for "Mail"
# GMAIL_USER=youremail@gmail.com
# GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Option 3: Custom SMTP (Mailgun, Brevo, Amazon SES, etc.)
# SMTP_HOST=smtp.mailgun.org
# SMTP_PORT=587
# SMTP_USER=postmaster@yourdomain.com
# SMTP_PASS=your-smtp-password

# Email sender name/address
EMAIL_FROM="Obsidian Audio" <noreply@yourdomain.com>

# ── Frontend URL (for email links) ────────────────────────────────────────────
APP_URL=https://sound-flow-six.vercel.app

# ── CORS ──────────────────────────────────────────────────────────────────────
# CORS is open to ALL origins by default (origin: true in server.js)
# No configuration needed — works with any Vercel/Netlify/custom domain
