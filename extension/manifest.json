{
  "manifest_version": 3,
  "name": "Obsidian Audio",
  "version": "1.0.0",
  "description": "Lightweight music streaming — play audio from YouTube without the video.",

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Obsidian Audio"
  },

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "permissions": [
    "storage",
    "offscreen",
    "tabs",
    "notifications"
  ],

  "host_permissions": [
    "https://api.yourapp.com/*",
    "http://localhost:5001/*"
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },

  "web_accessible_resources": [
    {
      "resources": ["offscreen.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
