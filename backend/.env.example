PORT=5000
NODE_ENV=development

# ── PostgreSQL ────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/obsidian_audio

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-random-256bit-secret

# ── Firebase Admin ────────────────────────────────────────
FIREBASE_SERVICE_ACCOUNT=./config/firebase-service-account.json

# ── CORS — MUST be HTTPS in production to fix Mixed Content ──
# Local dev:
CORS_ORIGIN=http://localhost:5173
# Production (comma-separated):
# CORS_ORIGIN=https://your-app.vercel.app,https://www.yourapp.com
